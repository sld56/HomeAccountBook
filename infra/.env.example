# 우리집 가계부 — 미니 PC 환경변수 템플릿
# 사용법: cp .env.example .env && chmod 600 .env && nano .env
# 절대 git에 커밋 금지

#### 도메인 ####
SITE_URL=https://gagyebu.yourdomain.com

#### Postgres ####
# 32자 이상 강력한 비밀번호: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_to_strong_password_32_chars_min

#### JWT (Auth + PostgREST 공통) ####
# openssl rand -hex 32 (반드시 32바이트=64hex)
JWT_SECRET=change_me_to_32_byte_random_hex_string_64_chars

# JWT_SECRET으로 생성: https://supabase.com/docs/guides/self-hosting/docker#api-keys
# 또는 미니 PC에서: node infra/scripts/gen-keys.mjs
ANON_KEY=eyJhbGciOi...generate_with_jwt_secret
SERVICE_ROLE_KEY=eyJhbGciOi...generate_with_jwt_secret

#### Realtime ####
# openssl rand -hex 32
REALTIME_SECRET=change_me_to_realtime_random_hex

#### SMTP (Resend) ####
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxx       # Resend API Key
SMTP_ADMIN_EMAIL=noreply@yourdomain.com   # 발신 이메일 (Resend 도메인 검증된 것)
SMTP_SENDER_NAME=우리집 가계부

#### 백업 ####
BACKUP_DIR=/var/backups/gagyebu
BACKUP_AGE_RECIPIENT=age1xxxxxxxxxxxxxxxxxxxxxxxxx   # age-keygen -o ~/.age/backup.key 후 공개키
B2_KEY_ID=                                            # Backblaze B2 (선택)
B2_APPLICATION_KEY=
B2_BUCKET=gagyebu-backup
